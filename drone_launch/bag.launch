<launch>

  <node pkg="rosbag" type="record" name="rosbag_record_drone" args="record
  /height_above_takeoff
  /dji_sdk/acceleration_ground_fused 
  /dji_sdk/angular_velocity_fused 
  /dji_sdk/attitude
  /dji_sdk/battery_state 
  /dji_sdk/flight_status 
  /dji_sdk/gps_health 
  /dji_sdk/gps_position
  /dji_sdk/height_above_takeoff
  /dji_sdk/imu /dji_sdk/rc
  /dji_sdk/velocity 
  /tf_static
  /tf
  /ouster/points
  /ouster/imu

  /arco/idmind_imu/imu
  /arco_os1_cloud_node/points_non_dense
  /arco_os1_cloud_node/imu
  
  /arco/cmd_vel_joy
  /arco/cmd_vel_nav
  /arco/idmind_motors/set_velocities
  /arco/idmind_motors/odom
  
  /mission_interface/load_mission
  /mission_interface/start_mission
  /mission_interface/trajectory_catenary
  /mission_interface/trajectory_lines_uav
  /mission_interface/trajectory_lines_ugv
  /mission_interface/trajectory_uav
  /mission_interface/trajectory_ugv
  /mission_interface/ugv_ready_for_mission
  /mission_interface/uav_ready_for_mission

  /Navigation/cancel
  /Navigation/feedback
  /Navigation/goal
  /Navigation/result
  /Navigation/status

  /UAVNavigation3D/cancel
  /UAVNavigation3D/feedback
  /UAVNavigation3D/goal
  /UAVNavigation3D/result
  /UAVNavigation3D/status

  /TakeOff/cancel
  /TakeOff/feedback
  /TakeOff/goal
  /TakeOff/result
  /TakeOff/status

  /usb_cam/image_raw/compressed
  /usb_cam/camera_info
 " />

</launch>
