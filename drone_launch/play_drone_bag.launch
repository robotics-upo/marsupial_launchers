<launch>
  <param name="use_sim_time" value="true"/>

  <arg name="base_frame_id" default="base_link"/>
  <arg name="odom_frame_id" default="odom"/>
  <arg name="global_frame_id" default="world"/>
   # Load by YAML file
  <arg name="map" default="teatro" />
  <arg name="map_path" default="$(find marsupial_optimizer)/maps/$(arg map).bt"/>
  <node pkg="dll" type="grid3d_node_dll" name="grid" output="screen" args="$(arg map_path)">
  </node>

  <arg name="bag" default="2023-03-01-16-26-25.bag"/>
  <arg name="bag_path" default="$(env HOME)/theatre_bags/$(arg bag)"/>
  <arg name="rate" default="1"/>
  <arg name="start" default="0"/>
  <node pkg="rosbag" type="play" name="play" args="$(arg bag_path) --clock -s $(arg start) -r $(arg rate)" required="true"/>

  <node pkg="rviz" type="rviz" name="rviz" args="-d $(find marsupial_launchers)/viz/experiment.rviz"/>

</launch>
