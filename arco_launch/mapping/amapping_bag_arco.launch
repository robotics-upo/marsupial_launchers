<launch>

    <param name="use_sim_time" value="true"/>
    <arg name="bag_name" default="2023-02-16-10-18-05.bag"/>
    <arg name="bag_file" default="$(env HOME)/Documents/Bags/edificio45/primera_planta/$(arg bag_name)"/>
    <!-- <arg name="bag_file" default="$(env HOME)/$(arg bag_name)"/> -->

    <include file="$(find marsupial_launchers)/arco_launch/mapping/amapping_arco.launch"/>
    <include file="$(find marsupial_launchers)/arco_launch/frames_arco.launch"/>
    <node name="bag_player" pkg="rosbag" type="play" args="$(arg bag_file) --clock --pause" output="screen">
        <remap from="/tf" to="/tf_non"/>
        <remap from="/tf_static" to="/tf_static_non"/>
    </node>

</launch>