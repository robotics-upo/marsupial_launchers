<!--
-->
<launch>
  
  # termica map conf
  <arg name="base_frame_id" default="arco/base_link"/>
  <arg name="odom_frame_id" default="arco/odom"/>
  <arg name="global_frame_id" default="world"/>
  <!-- <arg name="initial_x" default="80"/>
  <arg name="initial_y" default="39"/> -->
  <arg name="initial_x" default="40"/>
  <arg name="initial_y" default="25"/>
  <arg name="initial_z" default="2.0"/>
  <arg name="initial_a" default="3.1415"/> 
  <arg name="map" default="rellano45.bt" />
  <arg name="map_path" default="$(find marsupial_optimizer)/maps/$(arg map)"/>

  <arg name="in_cloud_topic" default="/arco_os1_cloud_node/points_non_dense"/>
  <arg name="imu_topic" default="/arco/idmind_imu/imu"/>

  <arg name="use_odometry" default="false"/>
  <arg name="use_imu" default="false"/> #for bags is TRUE


    # Fake odometry. You better use a good odometry estimator as LOAM
  <!-- <node pkg="tf2_ros" type="static_transform_publisher" name="odom_tf" args="0 0 0 0 0 0 arco/odom arco/base_link" unless="$(arg use_odometry)"/> -->

  <!-- <include file="$(find marsupial_launchers)/drone_launch/loam_odometry.launch" if="$(arg use_odometry)">
    <arg name="inverted_lidar" value="true"/>
  </include> -->
 
  # Launch DLL
  <node name="dll_node" type="dll_node" pkg="dll" output="screen">
    <remap from="/dll_node/initial_pose" to="/initialpose"/>
    <remap from="/imu" to="$(arg imu_topic)"/>
    <param name="in_cloud" value="$(arg in_cloud_topic)" />
    <param name="base_frame_id" value="$(arg base_frame_id)" />
    <param name="odom_frame_id" value="$(arg odom_frame_id)" />
    <param name="global_frame_id" value="$(arg global_frame_id)" />
    
    <param name="rate" value="10.0" />
    <param name="map_path" value="$(arg map_path)" />
    <param name="publish_point_cloud" value="true" />    
    <param name="update_min_d" value="0.01" />
    <param name="update_min_a" value="0.01" /> 
    <param name="update_min_time" value="0.1" />
    <param name="initial_x"   value="$(arg initial_x)"/>
    <param name="initial_y"   value="$(arg initial_y)"/>
    <param name="initial_z"   value="$(arg initial_z)"/>
    <param name="initial_a"   value="$(arg initial_a)"/>
    <param name="use_imu" value="$(arg use_imu)" />
    <param name="use_yaw_increments" value="true"/>   
    <param name="align_method" value="1" />  # 1: DLL, 2: NDT, 3: ICP
  </node>

  <node pkg="odom_to_tf" type="odom_to_tf.py" name="odom_to_tf" if="$(arg use_odometry)">
    <remap from="/odom" to="/arco/idmind_motors/odom"/>
    <param name="odom_frame_id" value="$(arg odom_frame_id)"/>
    <param name="base_frame_id" value="$(arg base_frame_id)"/>
    <!-- <param name="laser_frame" value="os1_lidar"/> -->
    <remap from="imu" to="/arco/idmind_imu/imu"/>
  </node>

</launch>	
